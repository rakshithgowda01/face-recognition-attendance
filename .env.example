# Copy this file to .env and change values if needed
# .env is never committed to GitHub

# Recognition sensitivity
# Lower = more permissive (0.30), Higher = more strict (0.45)
SIMILARITY_THRESHOLD=0.38

# How many top scores to average per student
TOP_K=5

# Augmented variants generated per photo
NUM_AUGMENTS=12

# Minutes before same student can be marked again
COOLDOWN_MINUTES=30